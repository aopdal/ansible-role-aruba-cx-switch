{#
# Jinja2 Template: ZTP Base Configuration for Aruba AOS-CX
#
# Purpose: Generate initial configuration for Zero Touch Provisioning
# Usage: Used during initial switch deployment to bootstrap basic connectivity
#
# Variables used:
# - inventory_hostname: Switch hostname from Ansible inventory
# - aoscx_ztp_admin_user: Admin username (default: admin)
# - aoscx_ztp_admin_password: Admin password (required)
# - mgmt_interfaces: Management interfaces from NetBox (filtered by mgmt_only=True)
#                    This includes both:
#                    - Dedicated mgmt interfaces (e.g., "mgmt")
#                    - VLAN interfaces used for management (e.g., "vlan100")
# - config_context: NetBox config context for management settings
#
# Generated configuration includes:
# - Basic system settings (hostname, user, security)
# - Management interface configuration (mgmt or VLAN SVI)
#   * Dedicated mgmt: Uses 'default-gateway' command under interface
#   * VLAN SVI: Uses global 'ip route 0.0.0.0/0 <gateway>' with auto-calculated gateway
#   * VRF support: Adds 'vrf <name>' to ip route if IP assigned to VRF in NetBox
# - Basic services (SSH, HTTPS API access)
# - ZTP-specific settings for initial deployment
#}
!
! Generated by Ansible Role: aopdal.aruba_cx_switch
! Template: templates/ztp_base_config.j2
! Generated: {{ ansible_date_time.iso8601 | default(ansible_facts.date_time.iso8601) | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}
! Host: {{ inventory_hostname }}
!
! === BASIC SYSTEM CONFIGURATION ===
!
hostname {{ inventory_hostname }}

! Allow unsupported transceivers (common in lab/dev environments)
allow-unsupported-transceiver confirm
allow-unsupported-transceiver log-interval none

!
! === USER CONFIGURATION ===
!
{% if aoscx_ztp_admin_user is defined and aoscx_ztp_admin_password is defined %}
user {{ aoscx_ztp_admin_user }} group administrators password plaintext {{ aoscx_ztp_admin_password }}
{% else %}
! Warning: No ZTP admin user configured - using Ansible user
user {{ ansible_user | default('admin') }} group administrators password plaintext {{ aoscx_ztp_admin_password | default('admin') }}
{% endif %}

!
! === ARUBA CENTRAL (DISABLE FOR ON-PREMISES) ===
!
aruba-central
    disable

!
! === MANAGEMENT INTERFACE CONFIGURATION ===
!
!
! === MANAGEMENT INTERFACE CONFIGURATION ===
!
{% if mgmt_interfaces is defined and mgmt_interfaces | length > 0 %}
{#- Modern NetBox format with mgmt_only=True -#}
{%   for intf in mgmt_interfaces %}
{%     if intf.ip_addresses is defined and intf.ip_addresses | length > 0 %}
interface {{ intf.name }}
{%       for ip in intf.ip_addresses %}
{%         if ip.address is defined %}
{#-           For VLAN interfaces, attach VRF first if defined -#}
{%           if 'vlan' in intf.name | lower %}
{%             if ip.vrf is defined and ip.vrf is not none and ip.vrf.name is defined %}
{%               set vrf_name = ip.vrf.name %}
{%               if vrf_name and vrf_name != 'default' and vrf_name | lower != 'global' %}
    vrf attach {{ vrf_name }}
{%               endif %}
{%             endif %}
{%           endif %}
    ip address {{ ip.address }}
{#-         For dedicated mgmt interface, use default-gateway command -#}
{%           if 'mgmt' in intf.name | lower and 'vlan' not in intf.name | lower %}
{%             if config_context is defined and mgmt_defaultgateway is defined %}
    default-gateway {{ mgmt_defaultgateway }}
{%             endif %}
{%           endif %}
{%           if config_context is defined and mgmt_nameserver is defined %}
    nameserver {{ mgmt_nameserver }}
{%           elif config_context is defined and dns_servers is defined %}
{%             for dns_server in dns_servers[:2] %}
    nameserver {{ dns_server }}
{%             endfor %}
{%           endif %}
{%         endif %}
{%       endfor %}
{%     else %}
! Warning: No IP address configured for management interface {{ intf.name }}
interface {{ intf.name }}
    ! Configure management IP manually or via DHCP:
    ! ip static <IP>/<MASK>
    ! default-gateway <GATEWAY>
    ! nameserver <DNS>
{%     endif %}
{%   endfor %}
{% elif interfaces is defined %}
{#- Fallback: Search all interfaces for management interfaces by name -#}
{%   set mgmt_found = false %}
{%   for intf in interfaces %}
{%     if 'mgmt' in intf.name | lower %}
{%       set mgmt_found = true %}
interface {{ intf.name }}
{%       if intf.ip_addresses is defined and intf.ip_addresses | length > 0 %}
{%         for ip in intf.ip_addresses %}
{%           if ip.address is defined %}
    ip static {{ ip.address }}
{%             if config_context is defined and mgmt_defaultgateway is defined %}
    default-gateway {{ mgmt_defaultgateway }}
{%             endif %}
{%             if config_context is defined and mgmt_nameserver is defined %}
    nameserver {{ mgmt_nameserver }}
{%             elif config_context is defined and dns_servers is defined %}
{%               for dns_server in dns_servers[:2] %}
    nameserver {{ dns_server }}
{%               endfor %}
{%             endif %}
{%           endif %}
{%         endfor %}
{%       else %}
    ! No IP address found in NetBox
    ! Configure management IP manually or via DHCP:
    ! ip static <IP>/<MASK>
    ! default-gateway <GATEWAY>
    ! nameserver <DNS>
{%       endif %}
{%     endif %}
{%   endfor %}
{%   if not mgmt_found %}
! Warning: No management interfaces found in NetBox
! Please configure management interface manually:
! interface mgmt
!     ip static <IP>/<MASK>
!     default-gateway <GATEWAY>
!     nameserver <DNS>
{%   endif %}
{% else %}
! Warning: No interfaces data available from NetBox
! Please configure management interface manually:
! interface mgmt
!     ip static <IP>/<MASK>
!     default-gateway <GATEWAY>
!     nameserver <DNS>
{% endif %}

!
! === DEFAULT ROUTE FOR VLAN MANAGEMENT INTERFACES ===
!
{% if mgmt_interfaces is defined and mgmt_interfaces | length > 0 %}
{%   for intf in mgmt_interfaces %}
{%     if 'vlan' in intf.name | lower and intf.ip_addresses is defined and intf.ip_addresses | length > 0 %}
{%       for ip in intf.ip_addresses %}
{%         if ip.address is defined %}
{%           set gateway = ip.address | ansible.utils.ipaddr('first_usable') %}
{%           set vrf_name = '' %}
{%           if ip.vrf is defined and ip.vrf is not none %}
{%             if ip.vrf.name is defined %}
{%               set vrf_name = ip.vrf.name %}
{%             endif %}
{%           endif %}
{%           if gateway %}
{%             if vrf_name and vrf_name != 'default' and vrf_name | lower != 'global' %}
ip route 0.0.0.0/0 {{ gateway }} vrf {{ vrf_name }}
{%             else %}
ip route 0.0.0.0/0 {{ gateway }}
{%             endif %}
{%           endif %}
{%         endif %}
{%       endfor %}
{%     endif %}
{%   endfor %}
{% endif %}

!
! === MANAGEMENT SERVICES ===
!
! Enable SSH server on management VRF
ssh server vrf mgmt

! Enable HTTPS REST API access
https-server vrf mgmt
https-server rest access-mode read-write

!
! === ZTP COMPLETION MARKER ===
!
! This configuration was applied via ZTP
! Role: aopdal.aruba_cx_switch
! Timestamp: {{ ansible_date_time.iso8601 | default(ansible_facts.date_time.iso8601) | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}
!
