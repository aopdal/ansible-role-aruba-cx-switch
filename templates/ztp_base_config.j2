{#
# Jinja2 Template: ZTP Base Configuration for Aruba AOS-CX
#
# Purpose: Generate initial configuration for Zero Touch Provisioning
# Usage: Used during initial switch deployment to bootstrap basic connectivity
#
# Variables used:
# - inventory_hostname: Switch hostname from Ansible inventory
# - aoscx_ztp_admin_user: Admin username (default: admin)
# - aoscx_ztp_admin_password: Admin password (required)
# - mgmt_interfaces: Management interfaces from NetBox (filtered by role)
# - config_context: NetBox config context for management settings
#
# Generated configuration includes:
# - Basic system settings (hostname, user, security)
# - Management interface configuration
# - Basic services (SSH, HTTPS API access)
# - ZTP-specific settings for initial deployment
#}
!
! Generated by Ansible Role: aopdal.aruba_cx_switch
! Template: templates/ztp_base_config.j2
! Generated: {{ ansible_date_time.iso8601 | default(ansible_facts.date_time.iso8601) | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}
! Host: {{ inventory_hostname }}
!
! === BASIC SYSTEM CONFIGURATION ===
!
hostname {{ inventory_hostname }}

! Allow unsupported transceivers (common in lab/dev environments)
allow-unsupported-transceiver confirm
allow-unsupported-transceiver log-interval none

!
! === USER CONFIGURATION ===
!
{% if aoscx_ztp_admin_user is defined and aoscx_ztp_admin_password is defined %}
user {{ aoscx_ztp_admin_user }} group administrators password plaintext {{ aoscx_ztp_admin_password }}
{% else %}
! Warning: No ZTP admin user configured - using Ansible user
user {{ ansible_user | default('admin') }} group administrators password plaintext {{ aoscx_ztp_admin_password | default('admin') }}
{% endif %}

!
! === ARUBA CENTRAL (DISABLE FOR ON-PREMISES) ===
!
aruba-central
    disable

!
! === MANAGEMENT INTERFACE CONFIGURATION ===
!
{% if mgmt_interfaces is defined and mgmt_interfaces | length > 0 %}
{%   for intf in mgmt_interfaces %}
{%     if intf.ip_addresses and intf.ip_addresses | length > 0 %}
interface {{ intf.name }}
{%       for ip in intf.ip_addresses %}
{%         if ip.address %}
    ip static {{ ip.address }}
{%           if config_context.mgmt_defaultgateway is defined %}
    default-gateway {{ config_context.mgmt_defaultgateway }}
{%           endif %}
{%           if config_context.mgmt_nameserver is defined %}
    nameserver {{ config_context.mgmt_nameserver }}
{%           elif config_context.dns_servers is defined %}
{%             for dns_server in config_context.dns_servers[:2] %}
    nameserver {{ dns_server }}
{%             endfor %}
{%           endif %}
{%         endif %}
{%       endfor %}
{%     else %}
! Warning: No IP address configured for management interface {{ intf.name }}
interface {{ intf.name }}
    ! Configure management IP manually or via DHCP
{%     endif %}
{%   endfor %}
{% else %}
! === FALLBACK: Legacy NetBox API format ===
{% if nb_interfaces is defined and nb_interfaces.json is defined %}
{%   for intf in nb_interfaces.json.results %}
{%     if 'mgmt' in intf.name %}
interface {{ intf.name }}
{%       for address in nb_ips.json.results %}
{%         if address.assigned_object.name == intf.name %}
    ip static {{ address.address }}
{%           if config_context.mgmt_defaultgateway is defined %}
    default-gateway {{ config_context.mgmt_defaultgateway }}
{%           endif %}
{%           if config_context.mgmt_nameserver is defined %}
    nameserver {{ config_context.mgmt_nameserver }}
{%           endif %}
{%         endif %}
{%       endfor %}
{%     endif %}
{%   endfor %}
{% else %}
! Warning: No management interfaces found
! Please configure management interface manually:
! interface mgmt
!     ip static <IP>/<MASK>
!     default-gateway <GATEWAY>
!     nameserver <DNS>
{% endif %}
{% endif %}

!
! === MANAGEMENT SERVICES ===
!
! Enable SSH server on management VRF
ssh server vrf mgmt

! Enable HTTPS REST API access
https-server vrf mgmt
https-server rest access-mode read-write

!
! === ZTP COMPLETION MARKER ===
!
! This configuration was applied via ZTP
! Role: aopdal.aruba_cx_switch
! Timestamp: {{ ansible_date_time.iso8601 | default(ansible_facts.date_time.iso8601) | default(lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ')) }}
!
