        "files.exclude": {
            "**/.git": false,
            "**/__pycache__": true,
            "**/*.pyc": true
        }
    },
    "extensions": {
        "recommendations": [
            "redhat.ansible",
            "redhat.vscode-yaml",
            "ms-python.python",
            "ms-python.vscode-pylance"
        ]
    }
}
