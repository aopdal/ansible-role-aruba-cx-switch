{
    "folders": [
        {
            "name": "🎭 Ansible Role - Aruba CX Switch",
            "path": "."
        },
        {
            "name": "🧪 Test Environment",
            "path": "/workspaces/aruba-role-testing"
        }
    ],
    "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "ansible.python.interpreterPath": "/usr/local/bin/python",
