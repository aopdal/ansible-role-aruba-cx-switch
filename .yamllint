---
# yamllint configuration for Ansible roles
# See https://yamllint.readthedocs.io/en/stable/configuration.html

extends: default

# Ignore certain files
ignore: |
  .git/
  .github/
  .cache/
  .molecule/
  .venv/
  tests/output/
  mkdocs.yml

rules:
  # Line length - network configs can be long
  line-length:
    max: 160
    level: warning

  # Comments
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable  # Required by ansible-lint

  # Indentation
  indentation:
    spaces: 2
    indent-sequences: true

  # Truthy values
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
    check-keys: false

  # Octal values (required by ansible-lint)
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

  # Document start
  document-start:
    present: true

  # Brackets
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1

  # Braces
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  # Empty values
  empty-values:
    forbid-in-block-mappings: false
    forbid-in-flow-mappings: true

  # Key duplicates
  key-duplicates: enable

  # Trailing spaces
  trailing-spaces: enable

  # New lines
  new-line-at-end-of-file: enable
  new-lines:
    type: unix
